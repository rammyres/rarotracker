[Unit]
Description=Raro Tracker - web app
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/rammyres/raro-tracker
EnvironmentFile=/home/rammyres/raro-tracker/.env
ExecStart=/home/rammyres/raro-tracker/venv/bin/gunicorn -w 2 -b 127.0.0.1:8077 app:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
