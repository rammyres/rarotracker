# Copie para .env e preencha (ou rode `python3 deploy/setup_env.py` para
# um assistente interativo que gera isso pra você). Em produção, prefira
# um EnvironmentFile do systemd em vez de .env (veja deploy/raro-tracker.service).

SECRET_KEY=troque-isto-por-algo-aleatorio

# --- E-mail ---
# EMAIL_BACKEND=smtp (padrão), EMAIL_BACKEND=sendmail (MTA local) ou
# EMAIL_BACKEND=resend (API HTTP da Resend — resend.com, só precisa da
# API key, sem SMTP).
EMAIL_BACKEND=smtp
SENDMAIL_PATH=/usr/sbin/sendmail
RESEND_API_KEY=

# Só usado se EMAIL_BACKEND=smtp.
# Exemplo Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use uma "App Password",
# não a senha normal da conta (precisa ter verificação em 2 etapas ativa).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
ALERT_EMAIL_TO=seu-email@exemplo.com

# --- Web Push (VAPID) ---
# Gere com: python3 -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); print(v.private_pem); print(v.public_pem)"
# ou use o utilitário deploy/generate_vapid_keys.py incluído neste projeto.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=mailto:seu-email@exemplo.com

# --- Telegram (gratuito, sem custo por mensagem) ---
# 1. Fale com @BotFather no Telegram, /newbot, copie o token gerado.
# 2. Pegue seu chat ID falando com @userinfobot (ou veja o README).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Endereço de referência para cálculo de frete (Brasil) ---
SHIP_TO_ZIP=64280-000
SHIP_TO_PROVINCE=PI

# --- Banco de dados (opcional, default é SQLite em instance/) ---
# DATABASE_URL=sqlite:////caminho/absoluto/raro_tracker.db
